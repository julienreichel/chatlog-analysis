# AWS / DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
DYNAMO_TABLE_NAME=chatlog-api-keys
DYNAMO_ANALYSIS_TABLE_NAME=chatlog-analysis-requests

# API Key HMAC secret (32+ random bytes, base64 or hex)
API_KEY_HMAC_SECRET=replace-with-a-long-random-secret-value

# Cognito settings are read automatically from amplify_outputs.json (generated by
# `npx ampx sandbox` or `npx ampx pipeline-deploy`).
# You can still override them manually with the variables below if needed:
# NUXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# NUXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# NUXT_PUBLIC_COGNITO_REGION=us-east-1
