# AWS / DynamoDB
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# API Key HMAC secret (32+ random bytes, base64 or hex)
API_KEY_HMAC_SECRET=replace-with-a-long-random-secret-value

# Cognito settings and DynamoDB table names are read automatically from
# amplify_outputs.json (generated by `npx ampx sandbox` or
# `npx ampx pipeline-deploy`).  You do NOT need to set them manually.
#
# Only set the variables below if you are NOT using Amplify to manage
# your infrastructure (e.g. pointing to pre-existing tables):
# DYNAMO_TABLE_NAME=my-api-keys-table
# DYNAMO_ANALYSIS_TABLE_NAME=my-analysis-table
